// ============================================================
// Firebase Storage Rules
// ============================================================
// Firebase Console > Storage > Rules

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == 'REPLACE_WITH_YOUR_UID';
    }
  }
}
