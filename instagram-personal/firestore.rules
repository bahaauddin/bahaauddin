// ============================================================
// Firestore Security Rules
// ============================================================
// انسخ هذا الملف وضعه في: Firebase Console > Firestore > Rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── البروفايل ─────────────────────────────────────────
    // القراءة: الجميع
    // الكتابة: المالك فقط
    match /profile/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == 'REPLACE_WITH_YOUR_UID';
    }

    // ── النوافذ ───────────────────────────────────────────
    match /windows/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == 'REPLACE_WITH_YOUR_UID';
    }

    // ── البوستات ──────────────────────────────────────────
    match /posts/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == 'REPLACE_WITH_YOUR_UID';
    }
  }
}
